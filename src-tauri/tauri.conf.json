{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trace",
  "version": "0.3.0",
  "identifier": "dev.trace.ide",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trace",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A modern ESP32 and Arduino IDE",
    "longDescription": "Trace is a focused desktop IDE for editing, compiling, uploading, and monitoring ESP32 Arduino sketches."
  }
}
